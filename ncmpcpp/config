ncmpcpp_directory = ~/.config/ncmpcpp

mpd_host = localhost
mpd_port = 6600

mpd_connection_timeout = 5
mpd_music_dir = ~/Music

mpd_crossfade_time = 0

# Hack voor links-uitgelijnde covers
visualizer_look = "  "
startup_screen = visualizer
startup_slave_screen = playlist
startup_slave_screen_focus = yes
locked_screen_width_part = 25

# Weergave van elementen
display_volume_level = no
display_bitrate = yes
header_visibility = yes

media_library_primary_tag = album_artist

# Opmaak van afspeellijst
playlist_display_mode = "classic"
song_list_format = "$(64){ ﴁ $(112)%a$(end)  $(232)%b$(end)}  $(112){%d.}%n$(end)$(100) %t$(end)$/r$R"
progressbar_look = "" 
#progressbar_look = " "

# Kleuren van elementen
progressbar_color = 238
progressbar_elapsed_color = 64
statusbar_color = 232
statusbar_time_color = 112
header_window_color = 112
main_window_color = 112
window_border_color = 238
active_window_border = 238
current_item_prefix = $(100)$r
current_item_suffix = $/r$(end)
current_item_inactive_column_prefix = $(112)$r
current_item_inactive_column_suffix = $/r$(end)

# Cover-script
execute_on_song_change="~/.config/ncmpcpp/ncmpcpp-ueberzug/ncmpcpp_cover_art.sh"
